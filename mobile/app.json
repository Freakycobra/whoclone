{
  "expo": {
    "name": "ConnectNow",
    "slug": "connectnow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A0F",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.connectnow.mobile",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.connectnow.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "ConnectNow needs camera access for video chat",
        "NSMicrophoneUsageDescription": "ConnectNow needs microphone access for video chat",
        "NSPhotoLibraryUsageDescription": "ConnectNow needs photo access to set your profile picture"
      }
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/messaging",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ConnectNow to access your camera for video chat."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow ConnectNow to access your microphone for video chat."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow ConnectNow to use your location for country-based matching."
        }
      ],

    ],
    "extra": {
      "eas": {
        "projectId": "084c8669-4657-4396-a4b7-17e2c7321eb1"
      }
    },
    "scheme": "connectnow"
  }
}
